# Dooray 메신저 인커밍 웹훅 URL (채널별 발급)
# 위험(critical) 알림용 채널
DOORAY_HOOK_URL_CRITICAL=https://hook.dooray.com/services/xxx/yyy/zzz
# 중요(warning) 알림용 채널 (같은 채널이면 동일 URL)
DOORAY_HOOK_URL_WARNING=https://hook.dooray.com/services/xxx/yyy/zzz

# NHN Cloud Exporter (LB, CDN, RDS 메트릭 수집, 선택 사항)
# ---------- 로드밸런서(LB) (401 해결) ----------
# Network API는 Keystone 토큰만 인식합니다. NHN_TENANT_ID + NHN_USERNAME + NHN_PASSWORD가 있으면
# 항상 Keystone을 사용하고, 없을 때만 OAuth2를 사용합니다 (OAuth2는 LB에서 401 나는 경우 많음).
# 1) NHN_NETWORK_ENDPOINT= 리전 LB API (예: https://kr1-api-network-infrastructure.nhncloudservice.com)
# 2) Keystone 설정: NHN_TENANT_ID=, NHN_USERNAME=, NHN_PASSWORD= (API 전용 비밀번호)
# 3) LOG_LEVEL=DEBUG 로 실행 시 "LB auth: Keystone" / "LB auth: OAuth2" 로 사용 중인 인증 확인 가능
# ----------
# NHN_NETWORK_ENDPOINT=https://kr1-api-network-infrastructure.nhncloudservice.com
# NHN_LB_OAUTH2_KEY=   # Keystone이 있으면 LB는 Keystone만 사용. 없을 때만 OAuth2 사용.
# NHN_LB_OAUTH2_SECRET=
# NHN_TENANT_ID=
# NHN_USERNAME=
# NHN_PASSWORD=
# NHN_LB_IDS=
# NHN_LB_NAMES=
# CDN – API 미사용. 외부 URL 상태만 체크 (쉼표 구분, 브라우저에서 여는 주소 그대로).
# NHN_CDN_HEALTH_CHECK_URLS=https://xxx.toastcdn.net/,https://yyy.toastcdn.net/path
# NHN_RDS_APPKEY=           # RDS/프로젝트 Appkey
# NHN_RDS_ACCESS_KEY_ID=    # API 보안 설정 > User Access Key ID (X-TC-AUTHENTICATION-ID)
# NHN_RDS_SECRETKEY=        # API 보안 설정 > Secret Access Key (X-TC-AUTHENTICATION-SECRET)
# NHN_RDS_API_BASE=         # RDS 전용 URL (기본: https://kr1-rds-mysql.api.nhncloudservice.com). CDN URL 넣지 말 것.
# SCRAPE_INTERVAL=60        # LB/CDN 수집 간격(초). 비용 절감 시 120~300 권장.
# RDS_SCRAPE_INTERVAL=300   # RDS 수집 간격(초). 비용 절감 시 300~600 권장.
# NHN_DISABLE_COLLECTORS= # 사용하지 않는 수집기 비활성화 (쉼표 구분: loadbalancer, cdn, rds). 401/404/DNS 오류 시 해당 수집기만 끄면 로그 정리됨

# Object Storage (OBS) health check. 공개 URL만 – 브라우저에서 여는 주소 그대로 넣기.
# OBS_PUBLIC_HEALTH_CHECK_URLS=https://example.toastcdn.net/container/object.jpg,https://...
# OBS_HEALTH_CHECK_INTERVAL=60   # 비용 절감 시 60~120 권장 (기본 30).
