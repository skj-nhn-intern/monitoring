# Dooray 메신저 인커밍 웹훅 URL (채널별 발급)
# 위험(critical) 알림용 채널
DOORAY_HOOK_URL_CRITICAL=https://hook.dooray.com/services/xxx/yyy/zzz
# 중요(warning) 알림용 채널 (같은 채널이면 동일 URL)
DOORAY_HOOK_URL_WARNING=https://hook.dooray.com/services/xxx/yyy/zzz

# NHN Cloud Exporter (LB, CDN, RDS 메트릭 수집, 선택 사항)
# 비용 절감: 외부 API 호출이므로 간격을 넉넉히 두는 편이 좋음. 권장(초):
#   SCRAPE_INTERVAL=120~300 (LB/CDN, 기본 60). LB 풀/멤버 상태는 2~5분 주기로도 충분.
#   RDS_SCRAPE_INTERVAL=300~600 (기본 300). DB/백업 상태는 5~10분 주기 권장.
#   OBS_HEALTH_CHECK_INTERVAL=60~120 (기본 30). 공개 URL 체크는 1~2분 주기 권장.
# LB/Identity: NHN_USERNAME= 이메일 또는 IAM 멤버 ID.
# NHN_TENANT_ID=   # 프로젝트(테넌트) ID (Compute > Instance > API Endpoint에서 확인)
# NHN_USERNAME=
# NHN_PASSWORD=   # 반드시 "API 전용 비밀번호" (콘솔 > Compute > Instance > API Endpoint 설정). 로그인 비밀번호 아님. LB 401 시 여기부터 확인.
# NHN_NETWORK_ENDPOINT=   # LB API 베이스 (예: https://kr1-api-network-infrastructure.nhncloudservice.com). 리전에 맞게 설정.
# NHN_LB_IDS=   # 수집할 LB ID (쉼표 구분). 지정 시 해당 LB의 pool/member/listener만 수집. 미설정 시 전체.
# NHN_LB_NAMES= # 또는 LB 이름으로 지정 (쉼표 구분).
# NHN_CDN_APPKEY=
# NHN_CDN_SECRETKEY=
# NHN_RDS_APPKEY=
# NHN_RDS_SECRETKEY=
# NHN_RDS_API_BASE=      # 기본값 kr1; DNS 오류 시 리전/호스트 확인 후 재설정
# SCRAPE_INTERVAL=60        # LB/CDN 수집 간격(초). 비용 절감 시 120~300 권장.
# RDS_SCRAPE_INTERVAL=300   # RDS 수집 간격(초). 비용 절감 시 300~600 권장.
# NHN_DISABLE_COLLECTORS= # 사용하지 않는 수집기 비활성화 (쉼표 구분: loadbalancer, cdn, rds). 401/404/DNS 오류 시 해당 수집기만 끄면 로그 정리됨

# Object Storage (OBS) health check. 공개 URL만 – 브라우저에서 여는 주소 그대로 넣기.
# OBS_PUBLIC_HEALTH_CHECK_URLS=https://example.toastcdn.net/container/object.jpg,https://...
# OBS_HEALTH_CHECK_INTERVAL=60   # 비용 절감 시 60~120 권장 (기본 30).
