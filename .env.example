# Dooray 메신저 인커밍 웹훅 URL (채널별 발급)
# 위험(critical) 알림용 채널
DOORAY_HOOK_URL_CRITICAL=https://hook.dooray.com/services/xxx/yyy/zzz
# 중요(warning) 알림용 채널 (같은 채널이면 동일 URL)
DOORAY_HOOK_URL_WARNING=https://hook.dooray.com/services/xxx/yyy/zzz

# NHN Cloud Exporter (LB, CDN, RDS 메트릭 수집, 선택 사항)
# NHN_TENANT_ID=
# NHN_USERNAME=
# NHN_PASSWORD=
# NHN_NETWORK_ENDPOINT=   # LB API (예: https://kr1-api-network-infrastructure.nhncloudservice.com)
# NHN_CDN_APPKEY=
# NHN_CDN_SECRETKEY=
# NHN_RDS_APPKEY=
# NHN_RDS_SECRETKEY=

# Object Storage (OBS) – API health check every 30s, multiple targets (e.g. replicated objects)
# NHN_OBS_API_URL=   # optional; if unset, uses object-store endpoint from token catalog
# NHN_OBS_TARGETS=container1,container2,container1/object-key   # comma-separated: container or container/object_key
# OBS_HEALTH_CHECK_INTERVAL=30
