# Dooray 메신저 인커밍 웹훅 URL (채널별 발급)
# 위험(critical) 알림용 채널
DOORAY_HOOK_URL_CRITICAL=https://hook.dooray.com/services/xxx/yyy/zzz
# 중요(warning) 알림용 채널 (같은 채널이면 동일 URL)
DOORAY_HOOK_URL_WARNING=https://hook.dooray.com/services/xxx/yyy/zzz

# NHN Cloud Exporter (LB, CDN, RDS 메트릭 수집, 선택 사항)
# NHN_TENANT_ID=
# NHN_USERNAME=
# NHN_PASSWORD=
# NHN_NETWORK_ENDPOINT=   # LB API (예: https://kr1-api-network-infrastructure.nhncloudservice.com)
# NHN_CDN_APPKEY=
# NHN_CDN_SECRETKEY=
# NHN_RDS_APPKEY=
# NHN_RDS_SECRETKEY=
# NHN_RDS_API_BASE=      # 기본값 kr1; DNS 오류 시 리전/호스트 확인 후 재설정
# RDS_SCRAPE_INTERVAL=300   # RDS 수집 간격(초). 기본 5분. DB 상태는 자주 안 바뀌므로 5분 권장; DNS 오류 시 로그 스팸도 줄어듦
# NHN_DISABLE_COLLECTORS= # 사용하지 않는 수집기 비활성화 (쉼표 구분: loadbalancer, cdn, rds). 401/404/DNS 오류 시 해당 수집기만 끄면 로그 정리됨

# Object Storage (OBS) – API health check every 30s. Public OBS도 동일 Swift API로 토큰 인증 HEAD 가능.
# URL 구조: {base}/v1/AUTH_tenant_id/{target} → target에 반드시 container 또는 container/object_key 지정
# NHN_OBS_API_URL=   # 단일 리전 (미설정 시 토큰 카탈로그의 object-store 1개 사용)
# NHN_OBS_API_URLS=  # 리전 무관: API 베이스 URL만 (container 미포함). 쉼표 구분 (예: https://kr1-objectstorage.nhncloudservice.com,https://kr2-objectstorage.nhncloudservice.com)
# NHN_OBS_TARGETS=photo,mybucket,mybucket/path/to/object   # container 또는 container/객체경로
# OBS_HEALTH_CHECK_INTERVAL=30
